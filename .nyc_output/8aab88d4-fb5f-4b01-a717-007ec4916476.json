 CI */\r\n  workers: process.env.CI ? 1 : undefined,\r\n  \r\n  /* Reporter to use */\r\n  reporter: [\r\n    ['html'],\r\n    ['list'],\r\n    ['json', { outputFile: 'test-results/test-results.json' }],\r\n  ],\r\n  \r\n  /* Shared settings for all the projects below */\r\n  use: {\r\n    /* Base URL to use in actions like `await page.goto('/')` */\r\n    baseURL: 'http://localhost:3000',\r\n    \r\n    /* Collect trace when retrying the failed test */\r\n    trace: 'on-first-retry',\r\n    \r\n    /* Take screenshot on failure */\r\n    screenshot: 'only-on-failure',\r\n    \r\n    /* Record video on failure */\r\n    video: 'retain-on-failure',\r\n    \r\n    /* Always show browser in UI mode */\r\n    headless: false,\r\n    \r\n    /* Launch options for visibility */\r\n    launchOptions: {\r\n      slowMo: 200,\r\n    },\r\n  },\r\n\r\n  /* Configure projects for major browsers */\r\n  projects: [\r\n    {\r\n      name: 'chromium',\r\n      use: { ...devices['Desktop Chrome'] },\r\n    },\r\n    \r\n    /* Test against mobile viewports */\r\n    {\r\n      name: 'Mobile Chrome',\r\n      use: { ...devices['Pixel 5'] },\r\n    },\r\n  ],\r\n\r\n  /* Run local dev server before starting the tests */\r\n  webServer: {\r\n    command: 'npm run dev',\r\n    url: 'http://localhost:3000',\r\n    reuseExistingServer: !process.env.CI,\r\n    timeout: 120 * 1000,\r\n  },\r\n});\r\n"],"mappings":";;;;;;AAAA,IAAAA,KAAA,GAAAC,OAAA;AAEA;AACA;AACA;AACA;AAHA,IAAAC,QAAA,GAAAC,OAAA,CAAAC,OAAA,GAIe,IAAAC,kBAAY,EAAC;EAC1BC,OAAO,EAAE,OAAO;EAEhB;EACAC,aAAa,EAAE,IAAI;EAEnB;EACAC,UAAU,EAAE,CAAC,CAACC,OAAO,CAACC,GAAG,CAACC,EAAE;EAE5B;EACAC,OAAO,EAAEH,OAAO,CAACC,GAAG,CAACC,EAAE,GAAG,CAAC,GAAG,CAAC;EAE/B;EACAE,OAAO,EAAEJ,OAAO,CAACC,GAAG,CAACC,EAAE,GAAG,CAAC,GAAGG,SAAS;EAEvC;EACAC,QAAQ,EAAE,CACR,CAAC,MAAM,CAAC,EACR,CAAC,MAAM,CAAC,EACR,CAAC,MAAM,EAAE;IAAEC,UAAU,EAAE;EAAiC,CAAC,CAAC,CAC3D;EAED;EACAC,GAAG,EAAE;IACH;IACAC,OAAO,EAAE,uBAAuB;IAEhC;IACAC,KAAK,EAAE,gBAAgB;IAEvB;IACAC,UAAU,EAAE,i